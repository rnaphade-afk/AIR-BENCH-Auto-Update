// Condensed AIR-BENCH update pipeline — one row, four stages.
// dot -Tpdf pipeline_workflow_compact.dot -o pipeline_workflow_compact.pdf
digraph pipeline_compact {
  rankdir=LR;
  bgcolor="white";
  nodesep=0.35; ranksep=0.45;
  node [shape=box, style="rounded,filled", fontname="Helvetica", fontsize=11,
        color="#8a8f94", penwidth=1.3, margin="0.20,0.13", fontcolor="#222222"];
  edge [color="#8a8f94", arrowsize=0.8, penwidth=1.3];

  tree [label="Semantic\ntree", shape=cylinder, fillcolor="#eef0f2", color="#555555"];
  s [label="1. Scrape\npolicies",          fillcolor="#e7eef6", color="#3E6D9C"];
  c [label="2. Classify\ninto taxonomy",   fillcolor="#e6f1ea", color="#4F8A6B"];
  g [label="3. Generate prompts\n(novel categories)", fillcolor="#f5ecd9", color="#C08A3E"];
  e [label="4. Export\ndataset",           fillcolor="#eee3ec", color="#8B5E83"];
  csv [label="prompt + judge\nCSVs", shape=cylinder, fillcolor="#ffffff", color="#555555"];

  tree -> s -> c -> g -> e -> csv;
}
