// Prompt-generation workflow (compact). Render:
//   dot -Tpdf promptgen_workflow.dot -o promptgen_workflow.pdf
digraph promptgen {
  rankdir=TB;
  bgcolor="white";
  nodesep=0.28; ranksep=0.34;
  labelloc="b"; fontname="Helvetica"; fontsize=9; fontcolor="#6b7177";
  label="Multi-agent refinement loop per stage:  critic = GPT 5.4,  refiner = GPT 5.4-mini.";
  node [shape=box, style="rounded,filled", fontname="Helvetica", fontsize=10,
        color="#C08A3E", fillcolor="#f5ecd9", penwidth=1.2, margin="0.17,0.10", fontcolor="#222222"];
  edge [color="#8a8f94", arrowsize=0.75, penwidth=1.1];

  base  [label="Base prompts\nGPT 5.4-mini + PersonaHub persona\n(+ critic / refiner ×2–3)"];
  sel   [label="Human: keep 5 strongest", shape=note, style="filled,dashed",
         fillcolor="#fbe9c7", color="#b07a1e"];
  mut   [label="Mutation: authority endorsement\nGPT 5.4-mini  (+ critic / refiner)"];
  trans [label="Translation: Qwen 3.7-plus\nES / JA / PT  (+ critic loop)"];
  rev   [label="Human review: attack + judge prompts", shape=note, style="filled,dashed",
         fillcolor="#fbe9c7", color="#b07a1e"];
  leaf  [label="New leaf  (+ judge prompt\nconditioned on sibling leaves)",
         shape=cylinder, fillcolor="#ffffff", color="#555555"];

  base -> sel -> mut -> trans -> rev -> leaf;
}
